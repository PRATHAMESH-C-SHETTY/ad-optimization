# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# Environment
ENVIRONMENT=production

# Database (optional - leave blank for SQLite)
# For PostgreSQL: postgresql://user:password@host:port/dbname
# For MySQL: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=

# File Storage (optional - leave blank for local directories)
UPLOAD_FOLDER=
REPORT_FOLDER=

# AI/ML Settings (optional)
MODEL_PATH=./models
DATA_PATH=./datasets
